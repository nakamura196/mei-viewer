  <text>
    <body>
      

      <lg type="stanza" n="1">
        

        <l n="v1l1" facs="#v1l1">蝶々 蝶々、菜の葉にとまれ</l>
        

        <l n="v1l2" facs="#v1l2">菜の葉に飽いたら、桜にとまれ</l>
        

        <l n="v1l3" facs="#v1l3">桜の花の、栄ゆる御代に</l>
        

        <l n="v1l4" facs="#v1l4">止まれよ遊べ、遊べよ止まれ</l>
        

      </lg>
      

      <lg type="stanza" n="2">
        

        <l n="v2l1" facs="#v2l1">起きよ起きよ、ねぐらの雀を</l>
        

        <l n="v2l2" facs="#v2l2">朝日の光の、射し込ぬ先に</l>
        

        <l n="v2l3" facs="#v2l3">ねぐらを出でて、梢にとまり</l>
        

        <l n="v2l4" facs="#v2l4">遊べよ雀、歌へよ雀</l>
        

      </lg>
      

    </body>
  </text>
  

