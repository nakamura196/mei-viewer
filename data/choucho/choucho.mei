      <sourceDesc>
        <source>
          <bibl>
            <title>小学唱歌集　初編</title>
            <respStmt><persName role="editor">文部省音楽取調掛 編</persName></respStmt>
            <pubPlace>東京</pubPlace>
            <publisher>文部省</publisher>
            <date>1881-1884</date>
            <identifier type="NDLJP">info:ndljp/pid/992051</identifier>
