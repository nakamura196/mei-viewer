  <meiHead>
    <fileDesc>
      <titleStmt>
        <title xml:lang="ja">蝶々（第十七）</title>
        <title xml:lang="en" type="translated">Chōchō (No. 17)</title>
        <respStmt>
          <persName role="encoder">MEI demo encoding</persName>
        </respStmt>
