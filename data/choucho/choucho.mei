        </source>
      </sourceDesc>
    </fileDesc>
    <encodingDesc>
      <editorialDecl>
        <p xml:lang="ja">第1フレーズ（4小節）は音高も検証済み。音高・リズムとも第十七「蝶々」第1段の楽譜（NDL pid 992051, 第17コマ右丁）を底本とし、五線上の符頭・連桁・符尾から判読した。拍子は原譜どおり 4/8。音高はソミミ／ファレレ／ドレミファ／ソソソ、音価は各小節が8分音符4つぶん（8分2＋4分1、第3小節のみ8分4）。「テフ ー テフ」のメリスマはスラーで表す。第2〜4段（第5〜16小節）も符号化し、その音高は本デモの音高エディタで原資料（facsimile）と照合のうえ人手で校訂した。リズム（各小節4/8）・小節構造・歌詞（底本どおりカタカナ）も底本に忠実。第2〜3段は低く平坦、第4段は下行する底本独自の旋律。なお木版の劣化により隣接音の別にはわずかな不確実性が残りうる。</p>
      </editorialDecl>
    </encodingDesc>
  </meiHead>
  <music>
    <!-- Facsimile: links the encoding back to the IIIF source image (NDL canvas 17).
         Coordinates are pixel boxes on the full-resolution image (4489 x 2013). -->
    <facsimile>
      <surface xml:id="s17" ulx="0" uly="0" lrx="4489" lry="2013">
        <graphic target="https://dl.ndl.go.jp/api/iiif/992051/R0000017/full/full/0/default.jpg"
                 width="4489" height="2013"/>
        <zone xml:id="sys1" ulx="2300" uly="380" lrx="4320" lry="800"/>
        <zone xml:id="sys2" ulx="2300" uly="790" lrx="4320" lry="1110"/>
        <zone xml:id="sys3" ulx="2300" uly="1130" lrx="4320" lry="1480"/>
        <zone xml:id="sys4" ulx="2300" uly="1490" lrx="4320" lry="1820"/>
      </surface>
    </facsimile>
    <body>
      <mdiv>
        <score>
          <scoreDef>
            <staffGrp>
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" keysig="0" meter.count="4" meter.unit="8"/>
            </staffGrp>
          </scoreDef>
          <section>
            <!-- 4/8拍子。各小節=8分音符4つぶん。底本の符頭・連桁・符尾から判読。
                 歌詞は底本の楽譜歌詞行どおり、第1番＝カタカナの旧仮名で表記。
                 「テフ ー テフ」= 1つ目の蝶(てふ=ちょう)を2音にわたり延ばし(長音符 ー)、
                 2つ目の蝶を4分にあてる。スラーは付けず、底本どおり ー で延ばしを示す。 -->
            <!-- m1: 蝶々 (ソ8 ミ8 ミ4) テフ ー テフ -->
            <measure n="1" xml:id="m1" facs="#sys1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n1" pname="g" oct="4" dur="8"><verse n="1"><syl>テフ</syl></verse></note>
                  <note xml:id="n2" pname="e" oct="4" dur="8"><verse n="1"><syl>ー</syl></verse></note>
                  <note xml:id="n3" pname="e" oct="4" dur="4"><verse n="1"><syl>テフ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <!-- m2: 蝶々 (ファ8 レ8 レ4) テフ ー テフ -->
            <measure n="2" xml:id="m2" facs="#sys1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n4" pname="f" oct="4" dur="8"><verse n="1"><syl>テフ</syl></verse></note>
                  <note xml:id="n5" pname="d" oct="4" dur="8"><verse n="1"><syl>ー</syl></verse></note>
                  <note xml:id="n6" pname="d" oct="4" dur="4"><verse n="1"><syl>テフ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <!-- m3: 菜の葉に (ド8 レ8 ミ8 ファ8) ナ ノ ハ ニ -->
            <measure n="3" xml:id="m3" facs="#sys1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n7" pname="c" oct="4" dur="8"><verse n="1"><syl>ナ</syl></verse></note>
                  <note xml:id="n8" pname="d" oct="4" dur="8"><verse n="1"><syl>ノ</syl></verse></note>
                  <note xml:id="n9" pname="e" oct="4" dur="8"><verse n="1"><syl>ハ</syl></verse></note>
                  <note xml:id="n10" pname="f" oct="4" dur="8"><verse n="1"><syl>ニ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <!-- m4: とまれ (ソ8 ソ8 ソ4) ト マ レ -->
            <measure n="4" xml:id="m4" facs="#sys1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n11" pname="g" oct="4" dur="8"><verse n="1"><syl>ト</syl></verse></note>
                  <note xml:id="n12" pname="g" oct="4" dur="8"><verse n="1"><syl>マ</syl></verse></note>
                  <note xml:id="n13" pname="g" oct="4" dur="4"><verse n="1"><syl>レ</syl></verse></note>
                </layer>
              </staff>
            </measure>

            <!-- 第2〜4段（1小節ずつ精読。起伏は確度高、低・中音域の厳密値は±1の不確実性が残り原資料で要照合）。歌詞は底本どおりカタカナ。 -->
            <measure n="5" xml:id="m5" facs="#sys2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n14" pname="g" oct="4" dur="8"><verse n="1"><syl>ナ</syl></verse></note>
                  <note xml:id="n15" pname="e" oct="4" dur="8"><verse n="1"><syl>ノ</syl></verse></note>
                  <note xml:id="n16" pname="e" oct="4" dur="8"><verse n="1"><syl>ハ</syl></verse></note>
                  <note xml:id="n17" pname="e" oct="4" dur="8"><verse n="1"><syl>ニ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="6" xml:id="m6" facs="#sys2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n18" pname="f" oct="4" dur="8"><verse n="1"><syl>ア</syl></verse></note>
                  <note xml:id="n19" pname="d" oct="4" dur="8"><verse n="1"><syl>イ</syl></verse></note>
                  <note xml:id="n20" pname="d" oct="4" dur="8"><verse n="1"><syl>タ</syl></verse></note>
                  <note xml:id="n21" pname="d" oct="4" dur="8"><verse n="1"><syl>ラ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="7" xml:id="m7" facs="#sys2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n22" pname="c" oct="4" dur="8"><verse n="1"><syl>サ</syl></verse></note>
                  <note xml:id="n23" pname="e" oct="4" dur="8"><verse n="1"><syl>ク</syl></verse></note>
                  <note xml:id="n24" pname="g" oct="4" dur="8"><verse n="1"><syl>ラ</syl></verse></note>
                  <note xml:id="n25" pname="g" oct="4" dur="8"><verse n="1"><syl>ニ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="8" xml:id="m8" facs="#sys2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n26" pname="e" oct="4" dur="8"><verse n="1"><syl>ト</syl></verse></note>
                  <note xml:id="n27" pname="e" oct="4" dur="8"><verse n="1"><syl>マ</syl></verse></note>
                  <note xml:id="n28" pname="e" oct="4" dur="4"><verse n="1"><syl>レ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="9" xml:id="m9" facs="#sys3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n29" pname="d" oct="4" dur="8"><verse n="1"><syl>サ</syl></verse></note>
                  <note xml:id="n30" pname="d" oct="4" dur="8"><verse n="1"><syl>ク</syl></verse></note>
                  <note xml:id="n31" pname="d" oct="4" dur="8"><verse n="1"><syl>ラ</syl></verse></note>
                  <note xml:id="n32" pname="d" oct="4" dur="8"><verse n="1"><syl>ノ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="10" xml:id="m10" facs="#sys3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n33" pname="d" oct="4" dur="8"><verse n="1"><syl>ハ</syl></verse></note>
                  <note xml:id="n34" pname="e" oct="4" dur="8"><verse n="1"><syl>ナ</syl></verse></note>
                  <note xml:id="n35" pname="f" oct="4" dur="4"><verse n="1"><syl>ノ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="11" xml:id="m11" facs="#sys3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n36" pname="e" oct="4" dur="8"><verse n="1"><syl>サ</syl></verse></note>
                  <note xml:id="n37" pname="e" oct="4" dur="8"><verse n="1"><syl>カ</syl></verse></note>
                  <note xml:id="n38" pname="e" oct="4" dur="8"><verse n="1"><syl>ユ</syl></verse></note>
                  <note xml:id="n39" pname="e" oct="4" dur="8"><verse n="1"><syl>ル</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="12" xml:id="m12" facs="#sys3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n40" pname="e" oct="4" dur="8"><verse n="1"><syl>ミ</syl></verse></note>
                  <note xml:id="n41" pname="f" oct="4" dur="8"><verse n="1"><syl>ヨ</syl></verse></note>
                  <note xml:id="n42" pname="g" oct="4" dur="4"><verse n="1"><syl>ニ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="13" xml:id="m13" facs="#sys4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n43" pname="g" oct="4" dur="8"><verse n="1"><syl>ト</syl></verse></note>
                  <note xml:id="n44" pname="e" oct="4" dur="8"><verse n="1"><syl>マ</syl></verse></note>
                  <note xml:id="n45" pname="e" oct="4" dur="8"><verse n="1"><syl>レ</syl></verse></note>
                  <note xml:id="n46" pname="e" oct="4" dur="8"><verse n="1"><syl>ヨ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="14" xml:id="m14" facs="#sys4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n47" pname="f" oct="4" dur="8"><verse n="1"><syl>ア</syl></verse></note>
                  <note xml:id="n48" pname="d" oct="4" dur="8"><verse n="1"><syl>ソ</syl></verse></note>
                  <note xml:id="n49" pname="d" oct="4" dur="4"><verse n="1"><syl>ベ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="15" xml:id="m15" facs="#sys4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n50" pname="c" oct="4" dur="8"><verse n="1"><syl>ア</syl></verse></note>
                  <note xml:id="n51" pname="e" oct="4" dur="8"><verse n="1"><syl>ソ</syl></verse></note>
                  <note xml:id="n52" pname="g" oct="4" dur="8"><verse n="1"><syl>ベ</syl></verse></note>
                  <note xml:id="n53" pname="g" oct="4" dur="8"><verse n="1"><syl>ヨ</syl></verse></note>
                </layer>
              </staff>
            </measure>
            <measure n="16" xml:id="m16" facs="#sys4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="n54" pname="e" oct="4" dur="8"><verse n="1"><syl>ト</syl></verse></note>
                  <note xml:id="n55" pname="e" oct="4" dur="8"><verse n="1"><syl>マ</syl></verse></note>
                  <note xml:id="n56" pname="e" oct="4" dur="4"><verse n="1"><syl>レ</syl></verse></note>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
